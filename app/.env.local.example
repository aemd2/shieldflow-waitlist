# ---------- Supabase (required) ----------
# Same Supabase project as the marketing site
NEXT_PUBLIC_SUPABASE_URL=https://fxhnzwzzizksxahlydzf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---------- Integration secret encryption (required to connect integrations) ----------
# Encrypts integration tokens/keys at rest (AES-256-GCM). Without it, connecting
# any integration is refused (fail closed — never stored in plaintext).
# Generate a 32-byte base64 key:  openssl rand -base64 32
SHIELDFLOW_ENCRYPTION_KEY=

# ---------- Everything below is OPTIONAL ----------
# Each feature shows a friendly "not configured" state when its key is missing.
# See SETUP.md for step-by-step instructions.

# Groq (free) — powers the AI Policy Generator + Co-Pilot.
# Get a free key (no credit card) at https://console.groq.com/keys
GROQ_API_KEY=

# Stripe billing (TEST MODE) — https://dashboard.stripe.com/test/apikeys
# STRIPE_WEBHOOK_SECRET comes from `npm run setup:stripe-webhook` (Stripe API,
# no CLI) or the webhook endpoint settings (deployed). SUPABASE_SERVICE_ROLE_KEY
# is needed by the webhook to write subscription rows (Supabase dashboard → API).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Google Workspace integration — OAuth app in "testing" mode is enough.
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry error monitoring — https://sentry.io (project DSN)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog analytics — https://posthog.com (project API key)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
